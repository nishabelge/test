provider "aws" {
  region     = "us-east-1"
  profile  =  "configs" 
} 

resource "aws_iam_user" "user1" {
  name = "vishal"
}

resource "aws_iam_user_login_profile" "user1" {
  user                    = aws_iam_user.user1.name
  password_reset_required = true
}

resource "null_resource" "ubuntu_user" {
  provisioner "remote-exec" {
    inline = [
      "sudo useradd -m vishal",
      "echo 'vishal:Password@123' | sudo chpasswd"
    ]

    connection {
      type        = "ssh"
      user        = "ubuntu"
      private_key = file("key.pem")
      host        = "YOUR_SERVER_IP"
    }
  }
}

resource "null_resource" "windows_user" {
  provisioner "remote-exec" {
    inline = [
      "net user vishal Password@123 /add"
    ]

    connection {
      type     = "winrm"
      user     = "Administrator"
      password = "AdminPassword"
      host     = "WINDOWS_SERVER_IP"
    }
  }
}
